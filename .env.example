RFI_APP_ENV=local
RFI_API_HOST=0.0.0.0
RFI_API_PORT=8001
RFI_API_HOST_PORT=8001
RFI_FRONTEND_HOST_PORT=3001
RFI_CORS_ALLOWED_ORIGINS=["http://localhost:3001"]

# Local container baseline: Postgres + Redis
RFI_DATABASE_URL=postgresql+psycopg://rfi:rfi-dev-password@postgres:5432/rfi
RFI_DATABASE_ECHO=false
RFI_DATABASE_AUTO_CREATE_SCHEMA=false
RFI_SEED_SCENARIOS_ON_STARTUP=true
RFI_JWT_SECRET=local-development-jwt-secret-key-change-me-0001
RFI_JWT_ACCESS_TOKEN_TTL_MINUTES=60
RFI_BOOTSTRAP_ADMIN_USERNAME=admin
RFI_BOOTSTRAP_ADMIN_PASSWORD=AdminPassword123!
RFI_BOOTSTRAP_ADMIN_DISPLAY_NAME=Platform Admin
RFI_BOOTSTRAP_ANALYST_USERNAME=analyst
RFI_BOOTSTRAP_ANALYST_PASSWORD=AnalystPassword123!
RFI_BOOTSTRAP_ANALYST_DISPLAY_NAME=Fraud Analyst
RFI_RATE_LIMIT_BACKEND=redis
RFI_RATE_LIMIT_REDIS_URL=redis://redis:6379/0
RFI_RATE_LIMIT_AUTH_REQUESTS=10
RFI_RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RFI_RATE_LIMIT_API_REQUESTS=120
RFI_RATE_LIMIT_API_WINDOW_SECONDS=60
RFI_AUDIT_LOG_RETENTION_DAYS=90

RFI_TEXT_SIGNAL_PROVIDER=keyword
RFI_REASONING_PROVIDER=local-rule-engine
RFI_EXPLANATION_PROVIDER=deterministic

RFI_HUGGINGFACE_API_TOKEN=
RFI_HUGGINGFACE_ZERO_SHOT_MODEL=facebook/bart-large-mnli
RFI_HUGGINGFACE_EXPLANATION_MODEL=HuggingFaceTB/SmolLM2-1.7B-Instruct
RFI_HUGGINGFACE_EXPLANATION_MAX_TOKENS=400
RFI_HUGGINGFACE_TIMEOUT_SECONDS=15

RFI_RELATIONALAI_USE_EXTERNAL_CONFIG=false
RFI_RELATIONALAI_DUCKDB_PATH=:memory:

API_BASE_URL=http://backend:8001/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1
