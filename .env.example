RFI_APP_ENV=local
RFI_API_HOST=0.0.0.0
RFI_API_PORT=8000
RFI_API_HOST_PORT=8001
RFI_FRONTEND_HOST_PORT=3001
RFI_CORS_ALLOWED_ORIGINS=["http://localhost:3001"]
RFI_DATABASE_URL=sqlite+pysqlite:///./data/rfi.db
RFI_DATABASE_ECHO=false
RFI_DATABASE_AUTO_CREATE_SCHEMA=true
RFI_SEED_SCENARIOS_ON_STARTUP=true

RFI_TEXT_SIGNAL_PROVIDER=keyword
RFI_REASONING_PROVIDER=local-rule-engine

RFI_HUGGINGFACE_API_TOKEN=
RFI_HUGGINGFACE_ZERO_SHOT_MODEL=facebook/bart-large-mnli
RFI_HUGGINGFACE_TIMEOUT_SECONDS=15

RFI_RELATIONALAI_USE_EXTERNAL_CONFIG=false
RFI_RELATIONALAI_DUCKDB_PATH=:memory:

API_BASE_URL=http://backend:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1
